<Window x:Class="InstallerClean.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        xmlns:chrome="clr-namespace:InstallerClean.Controls"
        xmlns:a11y="clr-namespace:InstallerClean.Helpers"
        Title="{loc:Translate Window.Main.Title}"
        SizeToContent="WidthAndHeight"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource Surface.Sidebar}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding Scan.ScanCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <!-- Star, not Auto: under SizeToContent the star row measures
                 to its content like Auto would, but once the window's
                 work-area MaxHeight binds (large OS text scales) the star
                 row is what shrinks, engaging the scan panel's internal
                 ScrollViewer, so the bottom nav below never clips. -->
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar. Row 0 height matches WindowChrome.CaptionHeight (32)
             so the icon and the 32px caption buttons share a centerline.
             Left margin (16) matches where the detail windows' title bars
             land (DetailWindowMargin 24 + StackPanel -8). -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="16,0,0,0">
            <chrome:DecorativeImage Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="{StaticResource GapRight.Sm}"/>
            <TextBlock Text="{loc:Translate Window.Main.Title}" Foreground="{StaticResource Text.Body}"
                       FontSize="{DynamicResource Type.Heading.Sm}" FontWeight="Medium"/>
        </StackPanel>
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    HorizontalAlignment="Right" VerticalAlignment="Top">
            <Button Style="{StaticResource CaptionButton}" Content="&#xE921;"
                    Click="MinimizeClick" AutomationProperties.Name="{loc:Translate Automation.Minimise}"
                    ToolTip="{loc:Translate Tooltip.Minimise}"/>
            <Button Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;"
                    Click="CloseClick" AutomationProperties.Name="{loc:Translate Automation.Close}"
                    ToolTip="{loc:Translate Tooltip.Close}"/>
        </StackPanel>

        <!-- Invisible scan-result announcer. Code-behind writes the
             composed "N unneeded files to clean up (size)" line here
             after a scan that found files; the visible count rows carry
             no LiveSetting because they rebind on every refresh,
             including the silent post-operation one. Opacity 0 keeps the
             element in the rendered tree, which the UIA bridge requires
             before it announces a text change. -->
        <TextBlock x:Name="ScanResultAnnouncer" Grid.Row="0"
                   HorizontalAlignment="Left" VerticalAlignment="Top"
                   Opacity="0" IsHitTestVisible="False"
                   AutomationProperties.LiveSetting="Polite"/>

        <!-- Row 1: the scan-result panel. The window is NoResize +
             SizeToContent (like the confirm dialogs), so it grows to fit
             this content exactly and normally never needs a scrollbar; a
             tall warning banner makes the window taller rather than
             clipping the action buttons. The MaxWidth is the content
             width a 720 window gives at 100% text scale and grows with
             the OS text-size factor, so the window widens with its text
             (up to the work-area MaxWidth set in code-behind) instead of
             starving the counts row. -->
        <Grid Grid.Row="1" Margin="{StaticResource MainContentMargin}"
              MaxWidth="{a11y:TextScaled 672}" HorizontalAlignment="Center"
              IsEnabled="{Binding IsMainContentInteractive}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Context: scan results. The explanation and counts sit in
                 a star row inside a ScrollViewer (NOT a StackPanel row: a
                 vertical StackPanel measures children at infinite height,
                 so an inner ScrollViewer never engages). When the window's
                 work-area MaxHeight binds at large text scales, this is
                 the block that scrolls; the separator, the action zone and
                 the bottom nav keep their full height below it. -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource BodyScrollRegion}"
                          AutomationProperties.Name="{loc:Translate Automation.Scroll.ScanResults}">
            <StackPanel>

                <!-- Explanatory text -->
                <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Body}" Margin="{StaticResource GapBottom.Lg}"
                           Text="{Binding MainExplanationText}"/>

                <!-- Pending reboot warning (Phosphor fill, tweaked !). DockPanel
                     (not a horizontal StackPanel) so the message wraps: a
                     horizontal StackPanel gives its child infinite width,
                     defeating TextWrapping and clipping the longer advisory
                     sentences off the right edge. Icon docks left and aligns to
                     the first line; the TextBlock fills the rest and wraps. -->
                <DockPanel Margin="{StaticResource GapBottom.Lg}"
                           Visibility="{Binding Scan.HasPendingReboot, Converter={StaticResource BoolToVis}}">
                    <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                          Fill="{StaticResource Status.Warning}" Width="16" Height="16" Stretch="Uniform"
                          DockPanel.Dock="Left" VerticalAlignment="Top" Margin="{StaticResource GapRight.Icon}"/>
                    <!-- LiveSetting=Polite + code-behind RaiseAutomationEvent
                         on the false→true HasPendingReboot transition.
                         The WPF UIA bridge has historically not re-
                         fired LiveRegionChanged when an element enters
                         the tree from Visibility=Collapsed; the bridge
                         only re-announces a text change inside an
                         already-rendered subtree. Code-behind raises
                         LiveRegionChanged explicitly so the banner's
                         appearance is announced. -->
                    <TextBlock x:Name="PendingRebootBannerText"
                               Text="{Binding Scan.PendingRebootBannerText}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Text.Body}" VerticalAlignment="Center"
                               AutomationProperties.LiveSetting="Polite"/>
                </DockPanel>

                <!-- Rule under the intro (and the pending-reboot warning when
                     shown): marks the explanation as its own section above the
                     scan counts. Matches the separator below the still-needed
                     count. -->
                <chrome:DecorativeBorder BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="0,1,0,0" Margin="{StaticResource GapBottom.Lg}"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Still needed. Wraps so a work-area width clamp at
                         large text scales shortens the line instead of
                         clipping it against the size column. -->
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Heading.Sm}"
                               TextWrapping="Wrap"
                               Text="{Binding Scan.RegisteredSummaryText}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Scan.RegisteredSizeDisplay}"
                               Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Heading.Sm}"
                               VerticalAlignment="Center" MinWidth="{a11y:TextScaled 72}" TextAlignment="Right"
                               Margin="{StaticResource GapX.Md}"/>
                    <Button Grid.Row="0" Grid.Column="2" Style="{StaticResource GhostPill}"
                            Content="{loc:Translate Action.Details}" Command="{Binding Chrome.OpenRegisteredDetailsCommand}"
                            MinHeight="28" Padding="12,0" FontSize="{DynamicResource Type.Heading.Sm}"
                            VerticalAlignment="Center" Margin="{StaticResource GapLeft.Md}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            AutomationProperties.Name="{loc:Translate Automation.ViewRegisteredFiles}"
                            AutomationProperties.HelpText="{loc:Translate Automation.ViewRegisteredFiles.HelpText}"/>
                </Grid>

                <!-- Registered files missing from disk. Sits as a footnote
                     under the still-needed count: a missing file is one of the
                     needed files, Windows still expects it, it just isn't on
                     disk. DockPanel (not a horizontal StackPanel) so the
                     advisory wraps; icon docks left, aligned to the first line. -->
                <DockPanel Margin="{StaticResource GapTop.Sm}"
                           Visibility="{Binding Scan.HasMissingFromDisk, Converter={StaticResource BoolToVis}}">
                    <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                          Fill="{StaticResource Status.Warning}" Width="16" Height="16" Stretch="Uniform"
                          DockPanel.Dock="Left" VerticalAlignment="Top" Margin="{StaticResource GapRight.Icon}"/>
                    <TextBlock x:Name="MissingFromDiskBannerText"
                               Text="{Binding Scan.MissingFromDiskSummaryText}"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource Text.Muted}" VerticalAlignment="Center"
                               AutomationProperties.LiveSetting="Polite"/>
                </DockPanel>

                <!-- Stale MSI registration entries (informational). The
                     MSI database carries a superseded-patch registration
                     for a file that's already gone from disk. Distinct
                     from the missing-from-disk banner above: that case
                     is load-bearing (file still claimed by Windows but
                     gone, future install/uninstall/patch will fail);
                     this case is benign (Windows considers the patch
                     removable already). Muted italic Caption to mark it
                     as low-emphasis next to the warning banner. -->
                <TextBlock x:Name="StaleMsiEntriesText"
                           Visibility="{Binding Scan.HasStaleMsiEntries, Converter={StaticResource BoolToVis}}"
                           Text="{Binding Scan.StaleMsiEntriesText}"
                           Foreground="{StaticResource Text.Muted}"
                           FontStyle="Italic" FontSize="{DynamicResource Type.Caption}"
                           TextWrapping="Wrap"
                           Margin="{StaticResource GapTop.Sm}"
                           AutomationProperties.LiveSetting="Polite"/>

            </StackPanel>
            </ScrollViewer>

            <!-- Separator -->
            <chrome:DecorativeBorder Grid.Row="2" BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="0,1,0,0"/>

            <!-- Action zone: orphaned + move/delete -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Orphaned -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Wraps for the same width-clamp reason as the
                         still-needed line above. -->
                    <TextBlock Grid.Column="0" VerticalAlignment="Center"
                               Foreground="{StaticResource Text.Heading}" FontSize="{DynamicResource Type.Heading.Sm}"
                               TextWrapping="Wrap"
                               Text="{Binding Scan.OrphanedSummaryText}"/>
                    <TextBlock Grid.Column="1" Text="{Binding Scan.OrphanedSizeDisplay}"
                               Foreground="{StaticResource Text.Heading}" FontSize="{DynamicResource Type.Heading.Sm}"
                               VerticalAlignment="Center" MinWidth="{a11y:TextScaled 72}" TextAlignment="Right"
                               Margin="{StaticResource GapX.Md}"/>
                    <Button Grid.Column="2" Style="{StaticResource GhostPill}"
                            Content="{loc:Translate Action.Details}" Command="{Binding Chrome.OpenOrphanedDetailsCommand}"
                            MinHeight="28" Padding="12,0" FontSize="{DynamicResource Type.Heading.Sm}"
                            VerticalAlignment="Center" Margin="{StaticResource GapLeft.Md}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            AutomationProperties.Name="{loc:Translate Automation.ViewOrphanedFiles}"
                            AutomationProperties.HelpText="{loc:Translate Automation.ViewOrphanedFiles.HelpText}"/>
                </Grid>

                <!-- Move location label -->
                <TextBlock Grid.Row="2" Text="{loc:Translate Section.Move.Location}"
                           Foreground="{StaticResource Text.Body}" FontSize="{DynamicResource Type.Heading.Sm}"
                           AutomationProperties.Name="{loc:Translate Automation.Section.MoveLocation}"/>

                <!-- Move destination -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <TextBox x:Name="MoveDestinationInput" Style="{StaticResource PillTextBox}"
                                 Text="{Binding Cleanup.MoveDestination, Mode=TwoWay,
                                                UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="8192"
                                 AutomationProperties.Name="{loc:Translate Automation.MoveDestinationFolder}"
                                 AutomationProperties.IsRequiredForForm="True"
                                 ToolTip="{loc:Translate Tooltip.MoveDestination}"
                                 ToolTipService.ShowsToolTipOnKeyboardFocus="False"/>
                        <!-- 15 = the box's 12 content padding + its 1px
                             border + the ~2px caret margin TextBoxView
                             reserves, so the watermark starts where the
                             typed text will. At 12 it sat visibly left
                             of the caret's leftmost position. -->
                        <TextBlock Text="{loc:Translate Action.MoveDestinationPlaceholder}"
                                   Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Body}" FontStyle="Italic"
                                   Padding="15,0" VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Cleanup.MoveDestination}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>

                    <Button Grid.Column="2" Style="{StaticResource GhostPill}" Padding="12,8"
                            Content="{loc:Translate Action.Browse}" Command="{Binding Cleanup.BrowseDestinationCommand}"/>
                </Grid>

                <!-- Buttons row. TabIndex puts Delete before Move so
                     Tab follows left-to-right visual order; DockPanel
                     Dock="Right" places Move at the far right and
                     Delete to its left, but XAML order alone would
                     visit Move first under Tab. -->
                <DockPanel Grid.Row="6" KeyboardNavigation.TabNavigation="Local">
                    <Button DockPanel.Dock="Right" Style="{StaticResource AccentPill}"
                            KeyboardNavigation.TabIndex="1"
                            Content="{loc:Translate Action.Move}" Command="{Binding Cleanup.MoveAllCommand}"
                            AutomationProperties.HelpText="{loc:Translate Automation.MoveAllFiles}"
                            ToolTip="{Binding Cleanup.MoveButtonTooltip}"
                            ToolTipService.ShowOnDisabled="True"/>

                    <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryPill}"
                            KeyboardNavigation.TabIndex="0"
                            Content="{loc:Translate Action.Delete}" Command="{Binding Cleanup.DeleteAllCommand}"
                            AutomationProperties.HelpText="{loc:Translate Automation.DeleteAllFiles}"
                            ToolTip="{loc:Translate Tooltip.Delete}"
                            ToolTipService.ShowOnDisabled="True"
                            Margin="{StaticResource GapRight.Sm}"/>

                    <!-- LiveSetting is on the overlay's matching pill
                         (the load-bearing surface during an operation);
                         this body-row pill sits behind the operating
                         overlay during the only window where the text
                         is changing, so re-announcing here doubles every
                         progress callback for screen readers. -->
                    <TextBlock DockPanel.Dock="Left" Text="{Binding Cleanup.OperationProgress}"
                               VerticalAlignment="Center" HorizontalAlignment="Left" Foreground="{StaticResource Text.Muted}"
                               FontSize="{DynamicResource Type.Body}"
                               TextTrimming="CharacterEllipsis" MaxWidth="{a11y:TextScaled 280}"/>
                </DockPanel>
            </Grid>

        </Grid>

        <!-- Bottom nav. Asymmetric Margin: 4 left because Re-scan
             and About are GhostPills with their own internal padding;
             24 right for clearance between the right-anchored chrome
             icons and the window-close hit area above. One-off;
             a literal Thickness rather than a Gap token. -->
        <DockPanel Grid.Row="2" LastChildFill="False" Margin="4,8,24,8"
                   KeyboardNavigation.TabNavigation="Local"
                   IsEnabled="{Binding IsMainContentInteractive}">
            <Button x:Name="RescanButton" DockPanel.Dock="Left" Style="{StaticResource GhostPill}"
                    KeyboardNavigation.TabIndex="0"
                    Content="{loc:Translate Action.Rescan}" Command="{Binding Scan.ScanCommand}"/>
            <Button DockPanel.Dock="Left" Style="{StaticResource GhostPill}"
                    KeyboardNavigation.TabIndex="1"
                    Content="{loc:Translate Action.About}" Command="{Binding Chrome.ShowAboutCommand}" Margin="4,0,0,0"/>
            <!-- TabIndex puts Star then Heart in keyboard order so Tab
                 follows the left-to-right visual order. DockPanel
                 Dock="Right" places Heart at the far right and Star to
                 its left; XAML order has Heart first, so without explicit
                 TabIndex the tab visit is Heart -> Star, reverse of
                 reading. -->
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostPill}"
                    KeyboardNavigation.TabIndex="3"
                    Command="{Binding Chrome.DonateCommand}"
                    AutomationProperties.Name="{loc:Translate Automation.BuyMeACuppa}"
                    FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                    ToolTipService.InitialShowDelay="0"
                    Padding="6,0" MinHeight="28">
                <Path Data="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"
                      Fill="{StaticResource Decoration.Heart}" Width="18" Height="18" Stretch="Uniform"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Path.RenderTransform>
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <!-- Hover grow honours "show animations": the scale
                                     plays only while ReduceMotion is false, so an
                                     animation-off user gets a static icon. IsMouseOver
                                     and the live setting gate it together, and a
                                     runtime toggle re-evaluates because ReduceMotion
                                     raises PropertyChanged. -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                        <Condition Binding="{Binding Source={x:Static a11y:AccessibilitySettings.Current}, Path=ReduceMotion}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <MultiDataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 To="1.2" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 To="1.2" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                    <MultiDataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 To="1.0" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 To="1.0" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.ExitActions>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <Button.ToolTip>
                    <ToolTip x:Name="HeartToolTip" Style="{StaticResource AccentTooltip}" Content="{loc:Translate Tooltip.BuyMeACuppa}"
                             Placement="Custom"/>
                </Button.ToolTip>
            </Button>
            <Button DockPanel.Dock="Right" Style="{StaticResource GhostPill}"
                    KeyboardNavigation.TabIndex="2"
                    Command="{Binding Chrome.StarOnGitHubCommand}"
                    AutomationProperties.Name="{loc:Translate Automation.LeaveStarOnGitHub}"
                    FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                    ToolTipService.InitialShowDelay="0"
                    Padding="6,0" MinHeight="28" Margin="{StaticResource GapRight.Md}">
                <Path Data="m12.672.668 3.059 6.197 6.838.993a.75.75 0 0 1 .416 1.28l-4.948 4.823 1.168 6.812a.75.75 0 0 1-1.088.79L12 18.347l-6.116 3.216a.75.75 0 0 1-1.088-.791l1.168-6.811-4.948-4.823a.749.749 0 0 1 .416-1.279l6.838-.994L11.327.668a.75.75 0 0 1 1.345 0Z"
                      Fill="{StaticResource Decoration.Star}" Width="18" Height="18" Stretch="Uniform"
                      RenderTransformOrigin="0.5,0.5">
                    <Path.RenderTransform>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                    </Path.RenderTransform>
                    <Path.Style>
                        <Style TargetType="Path">
                            <Style.Triggers>
                                <!-- Hover grow honours "show animations": the scale
                                     plays only while ReduceMotion is false, so an
                                     animation-off user gets a static icon. IsMouseOver
                                     and the live setting gate it together, and a
                                     runtime toggle re-evaluates because ReduceMotion
                                     raises PropertyChanged. -->
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True"/>
                                        <Condition Binding="{Binding Source={x:Static a11y:AccessibilitySettings.Current}, Path=ReduceMotion}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <MultiDataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 To="1.2" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 To="1.2" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.EnterActions>
                                    <MultiDataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                 To="1.0" Duration="0:0:0.15"/>
                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                 To="1.0" Duration="0:0:0.15"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </MultiDataTrigger.ExitActions>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Path.Style>
                </Path>
                <Button.ToolTip>
                    <ToolTip x:Name="StarToolTip" Style="{StaticResource AccentTooltip}" Content="{loc:Translate Tooltip.LeaveStarOnGitHub}"
                             Placement="Custom"/>
                </Button.ToolTip>
            </Button>
        </DockPanel>

        <!-- Scanning overlay -->
        <Grid Grid.RowSpan="3" Visibility="{Binding Scan.IsScanning, Converter={StaticResource BoolToVis}}"
              KeyboardNavigation.TabNavigation="Cycle"
              KeyboardNavigation.ControlTabNavigation="Cycle">
            <chrome:DecorativeBorder Background="{StaticResource Surface.Overlay}"/>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="240" Height="8" Margin="{StaticResource GapBottom.Md}"
                             AutomationProperties.Name="{loc:Translate Automation.ScanningProgress}"/>
                <TextBlock Text="{Binding Scan.ScanProgress}" Foreground="{StaticResource Text.Heading}"
                           FontSize="{DynamicResource Type.Heading.Sm}" HorizontalAlignment="Center" Margin="{StaticResource GapBottom.Sm}"
                           AutomationProperties.LiveSetting="Polite"/>
                <!-- Per-product ticker: names each package as the
                     enumeration passes it. Display-only; no LiveSetting,
                     because it updates once per installed product and a
                     live region would queue one announcement per product.
                     The milestone line above stays the announced one. -->
                <TextBlock Text="{Binding Scan.ScanTicker}"
                           Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Caption}"
                           HorizontalAlignment="Center" Margin="{StaticResource GapBottom.Lg}"
                           TextTrimming="CharacterEllipsis" MaxWidth="{a11y:TextScaled 240}"/>
                <Button x:Name="ScanCancelButton" Style="{StaticResource GhostPill}"
                        Content="{loc:Translate Action.Cancel}" Command="{Binding Scan.CancelScanCommand}"
                        MinHeight="28" Padding="16,0" FontSize="{DynamicResource Type.Body}"
                        HorizontalAlignment="Center"
                        FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                        AutomationProperties.Name="{loc:Translate Automation.CancelScan}"/>
            </StackPanel>
        </Grid>

        <!-- Operating overlay -->
        <Grid Grid.RowSpan="3" Visibility="{Binding Cleanup.IsOperating, Converter={StaticResource BoolToVis}}"
              KeyboardNavigation.TabNavigation="Cycle"
              KeyboardNavigation.ControlTabNavigation="Cycle">
            <chrome:DecorativeBorder Background="{StaticResource Surface.Overlay}"/>
            <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Pill}"
                    Padding="28,22" MinWidth="260"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <!-- Code-behind raises LiveRegionChanged on this heading when
                         the overlay appears: the view-model assigns the
                         "Moving/Deleting N files..." text after IsOperating flips,
                         so the overlay reveals from Collapsed with stale text and
                         the UIA bridge announces neither the reveal nor a text
                         change that lands before the first render. -->
                    <TextBlock x:Name="OperationHeadingText"
                               Text="{Binding Cleanup.OperationProgress}" Foreground="{StaticResource Text.Heading}"
                               FontSize="{DynamicResource Type.Heading.Sm}" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="{StaticResource GapBottom.Lg}"
                               AutomationProperties.LiveSetting="Polite"/>
                    <ProgressBar Value="{Binding Cleanup.OperationProgressPercent}"
                                 Minimum="0" Maximum="100"
                                 Width="200" Height="8" Margin="{StaticResource GapBottom.Sm}"
                                 AutomationProperties.Name="{loc:Translate Automation.OperationProgress}"/>
                    <!-- The 0,0,0,2 here and the 0,4,0,0 on the filename below sit
                         off the 8/12/16/24 spacing scale on purpose: they tighten
                         the "X of Y" / percentage row and the filename into one
                         compact block under the progress bar, where the scale's
                         8px would loosen the grouping. -->
                    <DockPanel Margin="0,0,0,2">
                        <TextBlock DockPanel.Dock="Right" Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Caption}">
                            <Run Text="{Binding Cleanup.OperationProgressPercent, Mode=OneWay, StringFormat='{}{0:F0}%'}"/>
                        </TextBlock>
                        <Grid>
                            <!-- Visible count: updates once per file. No
                                 LiveSetting; on a LiveSetting element every
                                 text change is announced, so a per-file
                                 binding queues one announcement per file and
                                 a large batch floods the speech queue. -->
                            <TextBlock Text="{Binding Cleanup.OperationProgressDetail}"
                                       Foreground="{StaticResource Text.Muted}"
                                       FontSize="{DynamicResource Type.Caption}"/>
                            <!-- Screen-reader twin: the same "X of Y files"
                                 line, updated at most once per tenth of the
                                 batch (first and last file always), so the
                                 announcements keep pace with speech. Opacity
                                 0 keeps it in the rendered tree, which the
                                 UIA bridge requires before it announces a
                                 text change, without painting over the live
                                 count. -->
                            <TextBlock Text="{Binding Cleanup.OperationProgressAnnouncement}"
                                       Foreground="{StaticResource Text.Muted}"
                                       FontSize="{DynamicResource Type.Caption}"
                                       Opacity="0" IsHitTestVisible="False"
                                       AutomationProperties.LiveSetting="Polite"/>
                        </Grid>
                    </DockPanel>
                    <!-- LiveSetting deliberately absent: the per-file
                         filename changes at I/O speed and would flood
                         the screen-reader queue faster than the user
                         can drain it. The throttled twin above carries
                         the "X of Y" count for the SR. -->
                    <TextBlock Text="{Binding Cleanup.OperationCurrentFileName}"
                               Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Caption}"
                               HorizontalAlignment="Center" Margin="0,4,0,0"
                               TextTrimming="CharacterEllipsis" MaxWidth="{a11y:TextScaled 240}"/>
                    <!-- Cancel button binds IsEnabled via the
                         CanCancelOperation predicate so a second click
                         after the cancel-in-flight is dropped. The
                         tooltip set by the IsCancellationRequested
                         trigger explains the disabled state during the
                         several-second window between Cancel and the
                         next CancellationToken checkpoint, mirroring
                         the splash window's pattern. -->
                    <Button x:Name="OperationCancelButton" Content="{loc:Translate Action.Cancel}"
                            Command="{Binding Cleanup.CancelOperationCommand}"
                            AutomationProperties.Name="{loc:Translate Automation.CancelOperation}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            HorizontalAlignment="Center" Margin="{StaticResource GapTop.Sm}"
                            MinHeight="28" Padding="16,0" FontSize="{DynamicResource Type.Body}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource GhostPill}">
                                <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Cleanup.IsCancellationRequested}" Value="True">
                                        <Setter Property="ToolTip" Value="{loc:Translate Tooltip.CancellingPending}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>
        <!-- Completion overlay. TabNavigation="Cycle" traps Tab
             inside the overlay. 1px BorderBrush matches the confirm
             dialogs. -->
        <Grid x:Name="CompletionOverlay" Grid.RowSpan="3" Visibility="{Binding Completion.IsComplete, Converter={StaticResource BoolToVis}}"
              KeyboardNavigation.TabNavigation="Cycle"
              KeyboardNavigation.ControlTabNavigation="Cycle">
            <!-- Clicking the dim margin dismisses the overlay (the
                 inner Border absorbs its own clicks). -->
            <chrome:DecorativeBorder Background="{StaticResource Surface.Overlay}"
                       MouseLeftButtonDown="CompletionDimAreaClick"
                       Cursor="Arrow"/>
            <!-- Card width scales with the OS text size so the copy keeps
                 its line length instead of wrapping into a tall sliver. -->
            <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Pill}"
                    BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="{StaticResource BorderThickness.Hairline}"
                    Padding="36,32" MinWidth="{a11y:TextScaled 340}" MaxWidth="{a11y:TextScaled 420}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <!-- Grid, not a StackPanel: the icon, heading and buttons
                     sit in Auto rows and the variable-length copy in a
                     star row, so when the card runs out of window height
                     at large text scales the copy scrolls and the buttons
                     stay visible. A vertical StackPanel would measure at
                     infinite height and clip the buttons instead. -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Icon -->
                    <chrome:DecorativeImage Grid.Row="0" Source="Assets/splash-icon.png"
                           Width="64" Height="64" HorizontalAlignment="Center"
                           RenderOptions.BitmapScalingMode="HighQuality"
                           Margin="{StaticResource GapBottom.Lg}"/>

                    <!-- Heading -->
                    <TextBlock x:Name="CompletionHeadingText" Grid.Row="1" Text="{Binding Completion.Heading}"
                               Foreground="{StaticResource Status.Success}" FontSize="{DynamicResource Type.Heading.Lg}" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="{StaticResource GapBottom.Sm}"
                               AutomationProperties.LiveSetting="Polite"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Style="{StaticResource BodyScrollRegion}"
                                  AutomationProperties.Name="{loc:Translate Automation.Scroll.ResultDetails}">
                    <StackPanel>

                    <!-- 6px bottom (off the 8/12/16/24 scale) tightens
                         the summary against the caption that follows
                         (the reassurance on an all-clear, the restore
                         hint after a Move or Delete); GapBottom.Sm (8)
                         loosens the pairing visibly. -->
                    <TextBlock x:Name="CompletionSummaryText" Text="{Binding Completion.Summary}"
                               Foreground="{StaticResource Text.Body}" FontSize="{DynamicResource Type.Heading.Sm}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,0,6"
                               AutomationProperties.LiveSetting="Polite"/>

                    <!-- All-clean reassurance. ShowAllClear sets it only
                         on a from-scratch all-clear (showReassurance);
                         it is empty after a post-cleanup rescan, so the
                         "two in three find nothing" framing never shows
                         to someone who just cleaned files. The empty-
                         string DataTrigger collapses it, matching the
                         Restore and Errors blocks. -->
                    <TextBlock Text="{Binding Completion.Reassurance}"
                               Foreground="{StaticResource Text.Body}" FontSize="{DynamicResource Type.Body}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,0,0,6">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Completion.Reassurance}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Restore guidance. Collapses when empty so the
                         all-clear overlay (which has no restore hint)
                         doesn't carry a phantom 30+ pixel gap from the
                         bottom margin plus line-height of an empty
                         TextBlock. Pattern matches the Errors Border
                         below. LiveSetting + the code-behind raise on
                         reveal: this line is the second half of the
                         outcome (where the files went after a Move or
                         Delete; the scan receipt on an all-clear). -->
                    <TextBlock x:Name="CompletionRestoreText" Text="{Binding Completion.Restore}"
                               AutomationProperties.LiveSetting="Polite"
                               Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Body}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="{StaticResource GapBottom.Xl}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Completion.Restore}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Error details (only visible when there are errors) -->
                    <Border Margin="{StaticResource GapBottom.Xl}" MaxHeight="{a11y:TextScaled 80}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Completion.Errors}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <!-- Named so the tab stop reads as a labelled field; an
                             unnamed read-only TextBox announces a bare "edit,
                             read-only" with no hint of what the text is. -->
                        <TextBox Text="{Binding Completion.Errors, Mode=OneWay}"
                                 Style="{StaticResource SelectableText}"
                                 AutomationProperties.Name="{loc:Translate Automation.CompletionErrors}"
                                 Foreground="{StaticResource Status.Warning}" FontSize="{DynamicResource Type.Caption}"
                                 TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
                    </Border>
                    </StackPanel>
                    </ScrollViewer>

                    <!-- Closes the result overlay, NOT the app: exiting
                         from here would trap the user with no way to
                         re-scan or open About. Auto-focused on overlay
                         show so Esc/Enter dismiss without mouse. -->
                    <Button x:Name="CompletionCloseButton" Grid.Row="3" Style="{StaticResource AccentPill}"
                            Content="{loc:Translate Action.Done}" Command="{Binding Completion.DismissCommand}"
                            IsDefault="True"
                            HorizontalAlignment="Center" MinWidth="120"
                            Margin="{StaticResource GapBottom.Sm}"
                            AutomationProperties.HelpText="{loc:Translate Automation.CloseResult}"/>

                    <!-- Send-result-log button. The lifetime lock in
                         AppSettings.HasSentResultLog hides it after a
                         send (success or failure) and across future
                         sessions, so no user is asked twice.
                         FocusVisualStyle is set explicitly so this
                         GhostPill paints a ring under Tab navigation. -->
                    <Button Grid.Row="4" Style="{StaticResource GhostPill}"
                            Content="{loc:Translate Action.SendResultLog}"
                            Command="{Binding Completion.SendResultLogCommand}"
                            Visibility="{Binding Completion.IsSendResultLogVisible, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center"
                            MinHeight="28" Padding="16,0" FontSize="{DynamicResource Type.Body}"
                            Margin="{StaticResource GapBottom.Sm}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            ToolTip="{Binding Completion.SendResultLogTooltip}"
                            AutomationProperties.HelpText="{loc:Translate Automation.SendResultLog.HelpText}"/>

                    <!-- Result-log status line. Shows "Sending..." while
                         the POST is in flight, "Thanks!" after a success,
                         or a localised failure reason. Empty (and so
                         collapsed) at every other moment.
                         AutomationProperties.LiveSetting=Polite makes
                         screen readers announce text changes here even
                         though focus is on Done; otherwise the silent-
                         skip and post-POST status copy is invisible to
                         users on Narrator/NVDA/JAWS. -->
                    <TextBlock x:Name="ResultLogStatusText" Grid.Row="5"
                               Text="{Binding Completion.ResultLogStatusMessage}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Foreground="{StaticResource Text.Muted}"
                               FontSize="{DynamicResource Type.Body}"
                               TextWrapping="Wrap" MaxWidth="{a11y:TextScaled 380}"
                               Margin="{StaticResource GapBottom.Sm}"
                               AutomationProperties.LiveSetting="Polite">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Completion.ResultLogStatusMessage}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Scan again -->
                    <Button Grid.Row="6" Style="{StaticResource GhostPill}"
                            Content="{loc:Translate Action.ScanAgain}" Command="{Binding Completion.RescanAfterCompletionCommand}"
                            HorizontalAlignment="Center"
                            MinHeight="28" Padding="16,0" FontSize="{DynamicResource Type.Body}"
                            FocusVisualStyle="{StaticResource SmallPillFocusVisual}"
                            AutomationProperties.HelpText="{loc:Translate Automation.RescanInstaller}"/>

                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
