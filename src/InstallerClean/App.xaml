<Application x:Class="InstallerClean.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Application resources are split into three layers:

          Themes/Primitives.xaml - raw colour atoms; never referenced
                                   from windows or component styles.
          Themes/Tokens.xaml     - semantic roles (Surface.*, Text.*,
                                   Action.*, Type.*, Radius.*, Border.*,
                                   BorderThickness.*, Gap.*, GapBottom.*,
                                   GapRight.*, GapLeft.*) consumed by
                                   both components and windows.
          Themes/Components.xaml - control styles (PrimaryPill, Card,
                                   ProgressBar, etc) consuming tokens.

        Tokens.xaml merges Primitives.xaml; Components.xaml merges
        Tokens.xaml; merging Components.xaml here pulls all three.
    -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Components.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>
