<Window x:Class="InstallerClean.ConfirmSendResultLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        xmlns:a11y="clr-namespace:InstallerClean.Helpers"
        Title="{loc:Translate Window.ConfirmSendResultLog.Title}"
        AutomationProperties.HelpText="{loc:Translate Automation.ConfirmSendResultLog}"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <!-- Card width scales with the OS text size so the JSON keeps its
         line length instead of forcing horizontal scrolling ever
         earlier as the text grows. -->
    <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Card}" Padding="{StaticResource Padding.ModalCard}"
            MaxWidth="{a11y:TextScaled 640}" MinWidth="{a11y:TextScaled 480}"
            BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="{StaticResource BorderThickness.Hairline}">
        <Grid>
            <Grid.RowDefinitions>
                <!-- The JSON box sits in a star row rather than a
                     StackPanel: a vertical StackPanel measures children
                     at infinite height, so the ScrollViewer inside the
                     box would never engage and the caption and buttons
                     below it would clip once the window's work-area
                     MaxHeight binds. Sized to content, the window shows
                     the whole report with no scrollbar; the box scrolls
                     only when the report genuinely cannot fit the
                     screen (an error-heavy report or a very large text
                     scale). -->
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{loc:Translate ConfirmSendResultLog.Title}"
                       Foreground="{StaticResource Text.Heading}" FontSize="{DynamicResource Type.Heading.Sm}"
                       TextWrapping="Wrap"
                       Margin="{StaticResource GapBottom.Md}"/>

            <Border Grid.Row="1"
                    Background="{StaticResource Surface.Sidebar}" CornerRadius="{StaticResource Radius.Inset}"
                    BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="{StaticResource BorderThickness.Hairline}"
                    Padding="12,10"
                    Margin="{StaticResource GapBottom.Md}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <!-- IsReadOnly so the JSON is copy-out-able but not
                         edit-before-Send. FontFamily is system monospace
                         so the JSON keys line up. KeyboardNavigation.TabIndex
                         sits behind the action buttons so a keyboard-first
                         user lands on Cancel and Send before the (large)
                         read-only box; screen readers still reach the box
                         and announce it via AutomationProperties.Name. -->
                    <TextBox x:Name="JsonText"
                             IsReadOnly="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource Text.Body}"
                             FontFamily="Consolas, Cascadia Mono, Lucida Console, monospace"
                             FontSize="{DynamicResource Type.Body}"
                             TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Disabled"
                             HorizontalScrollBarVisibility="Disabled"
                             KeyboardNavigation.TabIndex="2"
                             FocusVisualStyle="{StaticResource FlatTextBoxFocusVisual}"
                             AutomationProperties.Name="{loc:Translate Automation.ResultLogPreview}"/>
                </ScrollViewer>
            </Border>

            <TextBlock Grid.Row="2" Text="{loc:Translate ConfirmSendResultLog.Reassurance}"
                       Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Body}"
                       TextWrapping="Wrap"
                       Margin="{StaticResource GapBottom.Lg}"/>

            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Send is IsDefault. The modal opens in response to an
                     explicit Send-result click on the completion overlay
                     and the action is not destructive, so Enter confirms
                     and Esc cancels. ConfirmDeleteWindow inverts this
                     (Cancel as default) because Delete is destructive
                     and IsDefault on the affirmative would let a
                     reflexive Enter delete. -->
                <Button x:Name="CancelButton" Style="{StaticResource GhostPill}" Content="{loc:Translate Action.Cancel}"
                        Click="OnCancel" IsCancel="True"
                        KeyboardNavigation.TabIndex="0"
                        Margin="{StaticResource GapRight.Sm}"/>
                <Button Style="{StaticResource PrimaryPill}"
                        Content="{loc:Translate Action.SendResultLogConfirm}"
                        Click="OnSend" IsDefault="True"
                        KeyboardNavigation.TabIndex="1"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
