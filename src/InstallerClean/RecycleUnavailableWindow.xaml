<Window x:Class="InstallerClean.RecycleUnavailableWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        xmlns:a11y="clr-namespace:InstallerClean.Helpers"
        Title="{loc:Translate Window.RecycleUnavailable.Title}"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <!-- CaptionHeight=0: this is a centred-on-owner modal with no
             title-bar buttons, so no drag region is needed and the
             Border below claims the full window. -->
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <!-- Card width scales with the OS text size so the copy keeps its
         line length instead of wrapping into a tall sliver. -->
    <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Card}" Padding="{StaticResource Padding.ModalCard}"
            MaxWidth="{a11y:TextScaled 480}" MinWidth="{a11y:TextScaled 380}"
            BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="{StaticResource BorderThickness.Hairline}">
        <!-- Grid, not a StackPanel: the body and reassurance sit in a
             star row so they scroll once the window's work-area
             MaxHeight binds (very large text scales), keeping the
             heading and the three choice buttons visible; a vertical
             StackPanel measures children at infinite height, so the
             buttons would clip instead. -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <!-- DockPanel, not a horizontal StackPanel: a StackPanel hands
                 the TextBlock unbounded width, so TextWrapping never engages
                 and a long heading clips off the card edge. Icon docks left;
                 the TextBlock fills the rest and wraps. -->
            <DockPanel Grid.Row="0" Margin="{StaticResource GapBottom.Md}">
                <Path Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                      Fill="{StaticResource Status.Warning}" Width="16" Height="16" Stretch="Uniform"
                      DockPanel.Dock="Left" VerticalAlignment="Center" Margin="{StaticResource GapRight.Sm}"/>
                <TextBlock Text="{loc:Translate RecycleUnavailable.Heading}" Foreground="{StaticResource Text.Heading}" FontSize="{DynamicResource Type.Heading.Sm}"
                           TextWrapping="Wrap" VerticalAlignment="Center"/>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource BodyScrollRegion}"
                          AutomationProperties.Name="{loc:Translate Automation.Scroll.DialogBody}">
                <StackPanel>
                    <TextBlock x:Name="BodyText" Foreground="{StaticResource Text.Body}" FontSize="{DynamicResource Type.Body}"
                               TextWrapping="Wrap" Margin="{StaticResource GapBottom.Md}"/>

                    <TextBlock x:Name="ReassuranceText"
                               Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Body}"
                               TextWrapping="Wrap" Margin="{StaticResource GapBottom.Lg}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- WrapPanel rather than a horizontal StackPanel: three wide
                 buttons at a large text scale can outgrow even the scaled
                 card, and a StackPanel would push the leftmost off the
                 card edge; wrapping onto a second line keeps every choice
                 clickable. While they fit, it renders identically. -->
            <WrapPanel Grid.Row="2" HorizontalAlignment="Right">
                <!-- Cancel is the default to stop a reflexive Enter from
                     deleting; the same stance as ConfirmDeleteWindow. Move
                     is the visual primary (AccentPill, rightmost) because
                     it is the recommended safe path, but it is not the
                     keyboard default: an affirmative requires an explicit
                     pointer or Tab+Space. -->
                <!-- The help text describes the three-way choice: Cancel is
                     the first focus, and help text is only spoken for the
                     focused element (a window-level description is never
                     read because the window never has focus). -->
                <Button x:Name="CancelButton" Style="{StaticResource GhostPill}" Content="{loc:Translate Action.Cancel}"
                        Click="OnCancel" IsCancel="True" IsDefault="True"
                        AutomationProperties.HelpText="{loc:Translate Automation.RecycleUnavailable}"
                        Margin="{StaticResource GapRight.Sm}"/>
                <Button Style="{StaticResource DangerPill}" Content="{loc:Translate Action.DeletePermanently}"
                        Click="OnDeletePermanently"
                        Margin="{StaticResource GapRight.Sm}"
                        AutomationProperties.HelpText="{loc:Translate Automation.RecycleUnavailableDeletePermanently}"/>
                <Button Style="{StaticResource AccentPill}" Content="{loc:Translate Action.MoveInstead}"
                        Click="OnMove"
                        AutomationProperties.HelpText="{loc:Translate Automation.RecycleUnavailableMove}"/>
            </WrapPanel>
        </Grid>
    </Border>
</Window>
