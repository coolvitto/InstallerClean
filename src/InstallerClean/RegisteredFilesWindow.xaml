<Window x:Class="InstallerClean.RegisteredFilesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        Title="{loc:Translate Window.Registered.Title}"
        Width="950" Height="680"
        MinWidth="700" MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource Surface.Sidebar}"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32" GlassFrameThickness="-1"
                      ResizeBorderThickness="4"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Margin="{StaticResource DetailWindowMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
            <RowDefinition Height="2*"/><RowDefinition Height="20"/>
            <RowDefinition Height="3*"/><RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title bar. Row 0 height matches WindowChrome.CaptionHeight
             (32) so the icon and 32px close button share a centerline,
             matching About / Orphaned. -->
        <StackPanel Grid.Row="0" Orientation="Horizontal"
                    VerticalAlignment="Center" Margin="-8,-4,0,0">
            <Image Source="Assets/splash-icon.png" Width="16" Height="16"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="{StaticResource GapRight.Sm}"
                   AutomationProperties.Name=""/>
            <TextBlock Text="{loc:Translate Window.Registered.Title}" Foreground="{StaticResource Text.Body}"
                       FontSize="{StaticResource Type.Heading.Sm}" FontWeight="Medium"/>
        </StackPanel>
        <Button Grid.Row="0" Style="{StaticResource CaptionCloseButton}" Content="&#xE8BB;"
                Click="CloseClick" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="{StaticResource CloseButtonOverhangMargin}" AutomationProperties.Name="{loc:Translate Automation.CloseWindow}" ToolTip="{loc:Translate Tooltip.Close}"/>

        <TextBlock Grid.Row="1" Text="{loc:Translate Section.Registered.Products}" Foreground="{StaticResource Text.Body}"
                   FontSize="{StaticResource Type.Heading.Sm}"
                   AutomationProperties.Name="{loc:Translate Automation.Section.Products}"/>

        <Border Grid.Row="3" Style="{StaticResource CardNoPad}" ClipToBounds="True">
            <ListView x:Name="ProductsList" ItemsSource="{Binding Products}"
                      GridViewColumnHeader.Click="ColumnHeader_Click"
                      SelectedItem="{Binding SelectedProduct, Mode=TwoWay}"
                      BorderThickness="0" Background="Transparent"
                      Padding="0" Margin="0,-1,0,-6"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="{loc:Translate Field.ProductName}" Width="520"
                                        x:Name="ColProductName">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <DockPanel>
                                        <!-- Warning triangle on a missing row, docked left so
                                             the name fills the rest and still ellipsises. On a
                                             present row it is Collapsed and takes no width, so
                                             that name stays flush-left like every other row. -->
                                        <Path DockPanel.Dock="Left" Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                                              Fill="{StaticResource Status.Warning}" Width="14" Height="14" Stretch="Uniform"
                                              VerticalAlignment="Center" Margin="0,0,6,0"
                                              Visibility="{Binding IsMissing, Converter={StaticResource BoolToVis}}"/>
                                        <TextBlock Text="{Binding ProductName}" Foreground="{StaticResource Text.Heading}"
                                                   FontSize="{StaticResource Type.Heading.Sm}" TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" ToolTip="{Binding ProductName}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{loc:Translate Field.File}" Width="170"
                                        x:Name="ColFileName">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" Foreground="{StaticResource Text.Body}"
                                               FontSize="{StaticResource Type.Body}" TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding FullPath}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{loc:Translate Field.Size}" Width="90"
                                        x:Name="ColSizeBytes">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding SizeDisplay}" Foreground="{StaticResource Text.Body}"
                                                   FontSize="{StaticResource Type.Body}" TextAlignment="Right">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <!-- Missing row: the file is gone, so it has no size.
                                             "missing" in the warning colour stands in for it. -->
                                        <TextBlock Text="{loc:Translate Field.Missing}" Foreground="{StaticResource Status.Warning}"
                                                   FontSize="{StaticResource Type.Body}" TextAlignment="Right"
                                                   Visibility="{Binding IsMissing, Converter={StaticResource BoolToVis}}"/>
                                    </Grid>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{loc:Translate Field.Patches}" Width="80"
                                        x:Name="ColPatchCount">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding PatchCount}" Foreground="{StaticResource Text.Body}"
                                               FontSize="{StaticResource Type.Body}" TextAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/><ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{loc:Translate Section.Registered.Patches}" Foreground="{StaticResource Text.Body}"
                           FontSize="{StaticResource Type.Heading.Sm}"
                           AutomationProperties.Name="{loc:Translate Automation.Section.Patches}"/>
                <Border Grid.Row="2" Style="{StaticResource CardNoPad}">
                    <Grid>
                        <TextBlock Text="{loc:Translate Body.NoPatches}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Body}"
                                   FontStyle="Italic" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPatches}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ListBox ItemsSource="{Binding SelectedPatches}"
                                 BorderThickness="0" Background="Transparent"
                                 Padding="12,8" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasPatches}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,3">
                                        <TextBlock Text="{Binding FileName}" Foreground="{StaticResource Text.Heading}"
                                                   FontSize="{StaticResource Type.Heading.Sm}" TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FullPath}"/>
                                        <TextBlock Text="{Binding SizeDisplay}" FontSize="{StaticResource Type.Caption}">
                                            <TextBlock.Style>
                                                <!-- Text.Dim on the selected-row background
                                                     (Action.Primary.Background) is 3.34:1
                                                     (fails AA for normal text). Lift to
                                                     Text.Body on selection so a low-vision
                                                     user can read the size after arrow-key
                                                     navigation into a row. -->
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource Text.Dim}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource Text.Body}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="{loc:Translate Section.Registered.Details}" Foreground="{StaticResource Text.Body}"
                           FontSize="{StaticResource Type.Heading.Sm}"
                           AutomationProperties.Name="{loc:Translate Automation.Section.ProductDetails}"/>
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <TextBlock Text="{loc:Translate Body.NoProductSelected}"
                                   Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Body}" FontStyle="Italic"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   TextAlignment="Center" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{loc:Translate Body.NoMetadata}"
                                   Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Body}" FontStyle="Italic"
                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Visibility="{Binding ShowNoMetadata, Converter={StaticResource BoolToVis}}"/>
                        <!-- Missing-from-disk notice. Stands in for the metadata
                             panel when the selected product's file is gone: there
                             is no summary stream to read, so this explains what the
                             missing file is and how to recover it. Top-aligned and
                             scrollable because the note runs several paragraphs, so
                             it reads from the top rather than floating centred, and
                             a short window can still scroll to the end. The icon
                             docks top-left, beside the first line. -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding ShowMissing, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="M236.8,188.09,149.35,36.22h0a24.76,24.76,0,0,0-42.7,0L19.2,188.09a23.51,23.51,0,0,0,0,23.72A24.35,24.35,0,0,0,40.55,224h174.9a24.35,24.35,0,0,0,21.33-12.19A23.51,23.51,0,0,0,236.8,188.09ZM118,98a10,10,0,0,1,20,0v46a10,10,0,0,1,-20,0Zm10,96a14,14,0,1,1,14,-14A14,14,0,0,1,128,194Z"
                                      Fill="{StaticResource Status.Warning}" Width="20" Height="20" Stretch="Uniform"
                                      VerticalAlignment="Top" Margin="0,2,10,0"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding SelectedMissingNote}" Foreground="{StaticResource Text.Body}"
                                               FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"/>
                                    <!-- The note's closing line is a separate TextBlock so "explains
                                         this folder" can be a live Hyperlink (Run/Hyperlink/Run) into
                                         the README's recovery section; Hyperlink_Click routes it through
                                         the unelevated launcher. Top margin matches the blank-line gap
                                         between the bound paragraphs above. -->
                                    <TextBlock Foreground="{StaticResource Text.Body}" FontSize="{StaticResource Type.Body}"
                                               TextWrapping="Wrap" Margin="0,16,0,0"><Run Text="{loc:Translate Body.RegisteredMissingFromDisk.SeeAlso.Prefix}"/><Hyperlink NavigateUri="https://github.com/no-faff/InstallerClean#if-a-needed-file-goes-missing" Click="Hyperlink_Click" Style="{StaticResource SubtleLink}"><Run Text="{loc:Translate Body.RegisteredMissingFromDisk.SeeAlso.Link}"/></Hyperlink><Run Text="{loc:Translate Body.RegisteredMissingFromDisk.SeeAlso.Suffix}"/></TextBlock>
                                </StackPanel>
                            </Grid>
                        </ScrollViewer>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                      Visibility="{Binding ShowDetails, Converter={StaticResource BoolToVis}}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/><RowDefinition Height="8"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{loc:Translate Field.Author}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                                <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding SelectedDetails.Author, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                                         AutomationProperties.Name="{loc:Translate Field.Author}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{loc:Translate Field.Application}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                                <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding SelectedDetails.AppName, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                                         AutomationProperties.Name="{loc:Translate Field.Application}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="{loc:Translate Field.Title}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                                <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding SelectedDetails.Title, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                                         AutomationProperties.Name="{loc:Translate Field.Title}"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="{loc:Translate Field.Subject}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                                <TextBox Grid.Row="6" Grid.Column="2" Text="{Binding SelectedDetails.Subject, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                                         AutomationProperties.Name="{loc:Translate Field.Subject}"/>
                                <TextBlock Grid.Row="8" Grid.Column="0" Text="{loc:Translate Field.Keywords}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                                <TextBox Grid.Row="8" Grid.Column="2" Text="{Binding SelectedDetails.Keywords, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                                         AutomationProperties.Name="{loc:Translate Field.Keywords}"/>
                                <TextBlock Grid.Row="10" Grid.Column="0" Text="{loc:Translate Field.SigningCertificate}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"
                                           ToolTip="{loc:Translate Tooltip.SigningCertificate}"/>
                                <TextBox Grid.Row="10" Grid.Column="2" Text="{Binding SelectedDetails.DigitalSignature, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                                         AutomationProperties.Name="{loc:Translate Field.SigningCertificate}"/>
                                <TextBlock Grid.Row="12" Grid.Column="0" Text="{loc:Translate Field.FileSize}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                                <TextBox Grid.Row="12" Grid.Column="2" Text="{Binding SelectedProduct.SizeDisplay, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}"
                                         AutomationProperties.Name="{loc:Translate Field.FileSize}"/>
                                <TextBlock Grid.Row="14" Grid.Column="0" Text="{loc:Translate Field.Comment}" Foreground="{StaticResource Text.Dim}" FontSize="{StaticResource Type.Caption}"/>
                                <TextBox Grid.Row="14" Grid.Column="2" Text="{Binding SelectedDetails.Comments, Mode=OneWay}" Style="{StaticResource SelectableText}" Foreground="{StaticResource Text.Heading}" FontSize="{StaticResource Type.Body}" TextWrapping="Wrap"
                                         AutomationProperties.Name="{loc:Translate Field.Comment}"/>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <DockPanel Grid.Row="7" LastChildFill="False">
            <TextBlock DockPanel.Dock="Left" Text="{Binding Summary}"
                       Foreground="{StaticResource Text.Body}" FontSize="{StaticResource Type.Body}" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Style="{StaticResource PrimaryPill}"
                    Content="{loc:Translate Action.Close}" IsCancel="True"/>
        </DockPanel>
    </Grid>
</Window>
