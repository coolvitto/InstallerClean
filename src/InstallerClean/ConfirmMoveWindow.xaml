<Window x:Class="InstallerClean.ConfirmMoveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        xmlns:a11y="clr-namespace:InstallerClean.Helpers"
        Title="{loc:Translate Window.ConfirmMove.Title}"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <!-- CaptionHeight=0: this is a centred-on-owner modal with no
             title-bar buttons, so no drag region is needed and the
             Border below claims the full window. -->
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <!-- Card width scales with the OS text size so the copy keeps its
         line length instead of wrapping into a tall sliver. -->
    <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Card}" Padding="{StaticResource Padding.ModalCard}"
            MaxWidth="{a11y:TextScaled 440}" MinWidth="{a11y:TextScaled 320}"
            BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="{StaticResource BorderThickness.Hairline}">
        <!-- Grid, not a StackPanel: the destination (the one line that
             can run long) sits in a star row so it scrolls once the
             window's work-area MaxHeight binds (very large text scales),
             keeping the heading and the action buttons visible; a
             vertical StackPanel measures children at infinite height,
             so the buttons would clip instead. -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock x:Name="MessageText" Grid.Row="0" Foreground="{StaticResource Text.Heading}" FontSize="{DynamicResource Type.Heading.Sm}"
                       TextWrapping="Wrap" Margin="{StaticResource GapBottom.Sm}"/>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource BodyScrollRegion}"
                          AutomationProperties.Name="{loc:Translate Automation.Scroll.DialogBody}">
                <TextBlock x:Name="DestinationText" Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Body}"
                           TextWrapping="Wrap" Margin="{StaticResource GapBottom.Lg}"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel is the default for symmetry with the Confirm
                     Delete dialog: a reflexive Enter dismisses, never
                     commits. The help text describes the dialog's choice
                     from the first focus, as on Confirm Delete. -->
                <Button x:Name="CancelButton" Style="{StaticResource GhostPill}" Content="{loc:Translate Action.Cancel}"
                        Click="OnCancel" IsCancel="True" IsDefault="True"
                        AutomationProperties.HelpText="{loc:Translate Automation.ConfirmMove}"
                        Margin="{StaticResource GapRight.Sm}"/>
                <Button Style="{StaticResource AccentPill}" Content="{loc:Translate Action.Move}"
                        Click="OnMove"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
