<!--
    Component styles. Each Style here describes a control role
    (PrimaryPill, GhostPill, Card, etc) and consumes only semantic
    tokens from Tokens.xaml.

    Nothing in this file references a Primitive.* key. A component
    that needs a colour or numeric not yet in Tokens.xaml gets a new
    token there first, then consumes it from this file.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:loc="clr-namespace:InstallerClean.Resources"
                    xmlns:a11y="clr-namespace:InstallerClean.Helpers">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Tokens.xaml"/>
    </ResourceDictionary.MergedDictionaries>

    <!-- Global defaults. Bundled-font assignment on Window and
         TextBlock removes the per-control FontFamily repetition. -->
    <Style TargetType="Window">
        <Setter Property="FontFamily" Value="{StaticResource Type.FontFamily}"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Type.FontFamily}"/>
    </Style>

    <!-- Selectable text. A read-only TextBox styled to look like a
         TextBlock but with user-selectable contents. Useful for
         showing values worth copying (file paths, version strings,
         hashes). -->
    <Style x:Key="SelectableText" TargetType="TextBox">
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource Type.FontFamily}"/>
        <!-- IsTabStop=True so keyboard-only users can Tab onto a value
             and Ctrl+C it. Consumers that genuinely shouldn't be in
             the tab order set IsTabStop="False" at the site. -->
        <Setter Property="IsTabStop" Value="True"/>
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Header="{loc:Translate Action.Copy}" Command="ApplicationCommands.Copy"/>
                </ContextMenu>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Cards. Rounded surface containers. Card has standard inner
         padding; CardNoPad lets the consumer control its own padding
         (used for lists that paint their own row spacing). -->
    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface.Card}"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}"/>
        <Setter Property="Padding" Value="{StaticResource Gap.Lg}"/>
    </Style>

    <Style x:Key="CardNoPad" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource Surface.Card}"/>
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Pill}"/>
    </Style>

    <!-- Focus visuals. Three sizes match the three pill heights
         (40 / 30 / 28). The default focus visual at the bottom of
         this file applies to anything else that takes focus
         (a Hyperlink or plain Button) so keyboard navigation
         stays visible everywhere. -->
    <Style x:Key="PillFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource Radius.PillFocus}"
                            BorderThickness="{StaticResource BorderThickness.Standard}"
                            BorderBrush="{DynamicResource Text.Body}"
                            Margin="-2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactPillFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource Radius.CompactPillFocus}"
                            BorderThickness="{StaticResource BorderThickness.Standard}"
                            BorderBrush="{DynamicResource Text.Body}"
                            Margin="-2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SmallPillFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource Radius.Card}"
                            BorderThickness="{StaticResource BorderThickness.Standard}"
                            BorderBrush="{DynamicResource Text.Body}"
                            Margin="-2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Focus ring for flat, rectangular controls (the read-only JSON
         preview TextBox in ConfirmSendResultLogWindow). The pill
         visuals above sit around rounded controls and would paint a
         16px-rounded ring outside a sharp-cornered TextBox edge. This
         one uses a 2px corner radius so the ring shape tracks the
         underlying rectangle. -->
    <Style x:Key="FlatTextBoxFocusVisual">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Border CornerRadius="{StaticResource Radius.Tight}"
                            BorderThickness="{StaticResource BorderThickness.Standard}"
                            BorderBrush="{DynamicResource Text.Body}"
                            Margin="-2"
                            SnapsToDevicePixels="True"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Pill buttons. Four flavours share one visual language (40px
         minimum height, fully rounded, 14pt Medium label):
           AccentPill  - secondary action colour (CTA / Move).
           PrimaryPill - primary action colour (Browse / Add / Close).
           DangerPill  - destructive action colour (Delete).
           GhostPill   - text-only action with no fill (Settings / About).

         The pill heights here (and on the compact pills and PillTextBox
         below) are MinHeight, never Height: the label's font size tracks
         the OS text-scale factor, and a fixed height clips the label
         vertically once the scaled line height outgrows it. At 100% the
         minimum is exactly what renders. -->

    <Style x:Key="AccentPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="28,8"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Secondary.Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Secondary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Secondary.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PrimaryPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="28,8"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Primary.Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DangerPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="28,8"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="MinWidth" Value="120"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Danger.Background}"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Danger.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Danger.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="GhostPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Heading.Sm}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="20,8"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.Pill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Body}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Compact pill buttons (30 px minimum height). Compact variants
         for the About dialog action row. -->

    <Style x:Key="CompactPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Body}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="14,0"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource CompactPillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="{StaticResource Action.Primary.Background}"
                            CornerRadius="{StaticResource Radius.CompactPill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Pressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CompactGhostPill" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Body}"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource CompactPillFocusVisual}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent"
                            CornerRadius="{StaticResource Radius.CompactPill}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource Text.Body}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bg" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Inputs. -->

    <Style x:Key="PillTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource Surface.Card}"/>
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="CaretBrush" Value="{StaticResource Text.Heading}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Heading.Sm}"/>
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Padding" Value="12,0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource PillFocusVisual}"/>
        <!-- WPF auto-generates the TextBox right-click ContextMenu in
             code at show-time. That code path bypasses the implicit-
             style scope in Application.Resources, so the themed
             ContextMenu / MenuItem styles defined elsewhere in this
             file never reach it. An explicit ContextMenu Setter is
             the only route for the dark theme to apply. -->
        <Setter Property="ContextMenu">
            <Setter.Value>
                <ContextMenu>
                    <MenuItem Header="{loc:Translate Action.Cut}" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X"/>
                    <MenuItem Header="{loc:Translate Action.Copy}" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"/>
                    <MenuItem Header="{loc:Translate Action.Paste}" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V"/>
                    <MenuItem Header="{loc:Translate Action.SelectAll}" Command="ApplicationCommands.SelectAll" InputGestureText="Ctrl+A"/>
                </ContextMenu>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.Pill}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      VerticalAlignment="Center"
                                      Margin="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- List items. ListView and ListBox row styles. Selection
         highlight uses the primary action background (not the violet
         selection accent) so a selected row reads as "active
         selection" rather than "brand-flavoured". -->

    <Style TargetType="ListViewItem">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListViewItem">
                    <Border x:Name="Bd" Background="Transparent" Padding="4,6">
                        <GridViewRowPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.Sidebar}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ListBoxItem">
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Background="Transparent" Padding="2,2">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource Surface.Sidebar}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Detail-window column headers. Made keyboard-focusable so column sort
         works without a mouse: GridViewColumnHeader derives from ButtonBase,
         so Space/Enter on a focused header fires the Click the detail windows
         already handle. The Role=Padding trigger keeps the filler header WPF
         generates past the last column out of the tab order, where it would
         otherwise be a focusable stop with no column behind it. The
         IsKeyboardFocused fill gives the focused header a visible cue on the
         dark surface; the sort direction itself is exposed to a screen reader
         via AutomationProperties.ItemStatus (set in UpdateSortIndicators),
         not by the ▲/▼ glyph in the header text. -->
    <Style TargetType="GridViewColumnHeader">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="FontSize" Value="{DynamicResource Type.Caption}"/>
        <Setter Property="IsTabStop" Value="True"/>
        <Setter Property="Focusable" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewColumnHeader">
                    <Border x:Name="HeaderBorder" Background="Transparent" Padding="8,6"
                            BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource Surface.Sidebar}">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="HeaderBorder" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Role" Value="Padding">
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Focusable" Value="False"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Links. SubtleLink is an in-body Hyperlink that brightens to
         full Link colour on hover so it does not shout when sat in a
         paragraph. -->

    <Style x:Key="SubtleLink" TargetType="Hyperlink">
        <Setter Property="Foreground" Value="{StaticResource Link.Inline}"/>
        <Setter Property="TextDecorations" Value="None"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Style.Triggers>
            <!-- Underline AND brighten on hover so the link is
                 discoverable. Without an underline change, hover-only
                 reveals the link by colour shift, which fails for users
                 with reduced colour vision. The IsKeyboardFocused arm
                 mirrors hover for a keyboard-only user: tabbing to the
                 link surfaces the same colour + underline cue. -->
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource Link.Default}"/>
                <Setter Property="TextDecorations" Value="Underline"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter Property="Foreground" Value="{StaticResource Link.Default}"/>
                <Setter Property="TextDecorations" Value="Underline"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Scrollbar. Thin (8px), rounded, subtle thumb that brightens
         on hover. One keyed Thumb style plus a Style.Triggers branch
         covers both horizontal and vertical orientations. -->

    <Style x:Key="ThinThumb" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="Bg" Background="{StaticResource Scrollbar.Thumb}"
                            CornerRadius="{StaticResource Radius.Chip}"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Scrollbar.Thumb.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Scrollbar.Thumb.Hover}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Invisible but hit-testable page-track buttons. Without an
         Increase/Decrease repeat-button on the Track, clicking the groove
         above or below the thumb does nothing; a Transparent background
         (not null) is what makes the groove clickable to page up / down. -->
    <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="{TemplateBinding Background}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="MinWidth" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Border Background="Transparent"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="0">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="{x:Static ScrollBar.PageUpCommand}"/>
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThinThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="{x:Static ScrollBar.PageDownCommand}"/>
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="8"/>
                <Setter Property="MinHeight" Value="8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ScrollBar">
                            <Border Background="Transparent"
                                    CornerRadius="{StaticResource Radius.Chip}"
                                    Padding="0">
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="{x:Static ScrollBar.PageLeftCommand}"/>
                                    </Track.DecreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ThinThumb}"/>
                                    </Track.Thumb>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="{x:Static ScrollBar.PageRightCommand}"/>
                                    </Track.IncreaseRepeatButton>
                                </Track>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Caption buttons. Title-bar minimise / maximise / close. The
         CaptionClose style is distinct because the close button uses
         Action.CaptionClose.* on hover (red, matching the Windows
         convention) where the others use the standard Action.Primary
         background. -->

    <!-- The chrome glyphs (E921 minimise, E922 maximise, E923 restore,
         E8BB close) live in Segoe MDL2 Assets, the canonical Windows
         chrome font that ships with every Windows 10+ install. The
         template paints them with an explicit TextBlock rather than
         a ContentPresenter because the application-wide implicit
         <Style TargetType="TextBlock"> further up this file sets
         FontFamily to the bundled body font: ContentPresenter wraps
         a string Content in a TextBlock at runtime, that TextBlock
         picks up the implicit style, and a FontFamily setter on the
         enclosing Button never reaches it. An explicit TextBlock
         with a direct FontFamily setter wins because direct local
         values beat implicit-style values. -->
    <Style x:Key="CaptionButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <!-- Caption buttons match Windows native chrome and stay out
             of the keyboard focus path: Focusable=False avoids a click
             leaving the indigo accent on the button after minimise +
             Alt+Tab restore (the click would otherwise transfer focus
             to the button and the next paint would see IsKeyboardFocused
             still true). FocusVisualStyle is null because no focus path
             ever reaches them. -->
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent">
                        <TextBlock Text="{TemplateBinding Content}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Neutral}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CaptionCloseButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource Text.Muted}"/>
        <Setter Property="Width" Value="46"/>
        <Setter Property="Height" Value="32"/>
        <Setter Property="WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" Background="Transparent">
                        <TextBlock Text="{TemplateBinding Content}"
                                   FontFamily="Segoe MDL2 Assets" FontSize="12"
                                   Foreground="{TemplateBinding Foreground}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.CaptionClose.Hover}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.CaptionClose.Pressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Tooltips. AccentTooltip is the indigo accent tooltip for
         the donate / star buttons that shouts a little; the implicit
         ToolTip style below is the default for everything else. -->

    <Style x:Key="AccentTooltip" TargetType="ToolTip">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <!-- Wrap width scales with the OS text size; a fixed cap
             squeezes scaled text into an ever taller, thinner column. -->
        <Setter Property="MaxWidth" Value="{a11y:TextScaled 280}"/>
        <Setter Property="Placement" Value="Top"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource Action.Secondary.Background}"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="10,6">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{StaticResource Text.Heading}"
                                   FontSize="{DynamicResource Type.Body}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default ToolTip for attribute-syntax ToolTip="..." usages. Dark
         card surface, hairline border, body text. -->
    <Style TargetType="ToolTip">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <!-- Wrap width scales with the OS text size, as on AccentTooltip. -->
        <Setter Property="MaxWidth" Value="{a11y:TextScaled 320}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource Surface.Sidebar}"
                            BorderBrush="{StaticResource Action.Primary.Background}"
                            BorderThickness="{StaticResource BorderThickness.Hairline}"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="10,6">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="{StaticResource Text.Body}"
                                   FontSize="{DynamicResource Type.Body}"
                                   TextWrapping="Wrap"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Default focus visual. Catches anything that takes focus but
         has no FocusVisualStyle override (plain Buttons, Hyperlinks).
         Pill buttons opt out via their own *FocusVisual styles
         above. -->
    <Style x:Key="{x:Static SystemParameters.FocusVisualStyleKey}">
        <Setter Property="Control.Template">
            <Setter.Value>
                <ControlTemplate>
                    <Rectangle RadiusX="2" RadiusY="2"
                               Stroke="{DynamicResource Text.Body}"
                               StrokeThickness="{StaticResource Border.Hairline}"
                               SnapsToDevicePixels="True"
                               Margin="-1"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Progress bar. Slim dark bar. Determinate uses PART_Indicator
         (WPF stock). Indeterminate has two presentations: a sweeping
         bar when animations are on, and a static full-width fill when
         Windows' "show animations" is off (reduced motion). The sweep
         moves the RepeatBehavior onto the DoubleAnimation rather than
         the wrapping Storyboard so the compiled BAML carries no literal
         "Storyboard RepeatBehavior=Forever" attribute pair.

         The sweep translates the 80 px bar from X=-80 to X=320 (max bar
         width 240 px). DoubleAnimation can't template-bind ActualWidth,
         so a wider indeterminate consumer needs the To value raised. -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background" Value="{StaticResource Surface.Sidebar}"/>
        <Setter Property="Foreground" Value="{StaticResource Action.Secondary.Background}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border CornerRadius="{StaticResource Radius.Chip}"
                            Background="{TemplateBinding Background}"
                            ClipToBounds="True">
                        <Grid>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator"
                                    CornerRadius="{StaticResource Radius.Chip}"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"/>
                            <Border x:Name="IndeterminateBar"
                                    Width="80"
                                    CornerRadius="{StaticResource Radius.Chip}"
                                    HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"
                                    Visibility="Collapsed"
                                    RenderTransformOrigin="0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="IndeterminateTransform"/>
                                </Border.RenderTransform>
                            </Border>
                            <!-- Reduced-motion stand-in for the sweep: a static,
                                 full-width fill shown instead of IndeterminateBar
                                 when "show animations" is off, so an indeterminate
                                 bar still reads as busy without moving. -->
                            <Border x:Name="StaticBusyBar"
                                    CornerRadius="{StaticResource Radius.Chip}"
                                    Background="{TemplateBinding Foreground}"
                                    Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Indeterminate with animations on: the bar sweeps. The
                             storyboard is named so the companion ExitActions stop
                             it the moment the bar stops being indeterminate or
                             "show animations" is switched off mid-run, rather than
                             leaving a clock running on a hidden element (and
                             stacking a second clock if it later re-enters). -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsIndeterminate, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                <Condition Binding="{Binding Source={x:Static a11y:AccessibilitySettings.Current}, Path=ReduceMotion}" Value="False"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="IndeterminateBar" Property="Visibility" Value="Visible"/>
                            <MultiDataTrigger.EnterActions>
                                <BeginStoryboard x:Name="IndeterminateMarquee">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="IndeterminateTransform"
                                                         Storyboard.TargetProperty="X"
                                                         From="-80" To="320"
                                                         Duration="0:0:1.4"
                                                         RepeatBehavior="Forever"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </MultiDataTrigger.EnterActions>
                            <MultiDataTrigger.ExitActions>
                                <StopStoryboard BeginStoryboardName="IndeterminateMarquee"/>
                            </MultiDataTrigger.ExitActions>
                        </MultiDataTrigger>
                        <!-- Indeterminate with animations off: a static full-width
                             fill stands in for the sweep, so an animation-off user
                             sees no movement while the bar still reads as busy. -->
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding IsIndeterminate, RelativeSource={RelativeSource TemplatedParent}}" Value="True"/>
                                <Condition Binding="{Binding Source={x:Static a11y:AccessibilitySettings.Current}, Path=ReduceMotion}" Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="PART_Indicator" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="StaticBusyBar" Property="Visibility" Value="Visible"/>
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Context menu and menu item. Padding/CornerRadius literals
         here are per-control tunings, not spacing-token decisions:
         the Spacing scale is uniform and does not capture the
         asymmetric (12,6) padding menu rows want. -->

    <Style TargetType="ContextMenu">
        <Setter Property="Background" Value="{StaticResource Surface.Sidebar}"/>
        <Setter Property="BorderBrush" Value="{StaticResource Action.Primary.Background}"/>
        <Setter Property="BorderThickness" Value="{StaticResource BorderThickness.Hairline}"/>
        <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
        <Setter Property="Padding" Value="2"/>
        <Setter Property="HasDropShadow" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.Chip}"
                            Padding="{TemplateBinding Padding}">
                        <StackPanel IsItemsHost="True"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource Text.Body}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="Bg" Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="{StaticResource Radius.Tight}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" x:Name="GestureText"
                                       Text="{TemplateBinding InputGestureText}"
                                       Margin="20,0,0,0"
                                       Foreground="{StaticResource Text.Dim}"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="{StaticResource Action.Primary.Background}"/>
                            <Setter Property="Foreground" Value="{StaticResource Text.Heading}"/>
                            <!-- Text.Dim on Action.Primary.Background is 3.34:1 (fails AA
                                 4.5:1 for normal text); the highlighted row must lift the
                                 gesture column too, not just the header. -->
                            <Setter TargetName="GestureText" Property="Foreground" Value="{StaticResource Text.Body}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource Text.Dim}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
