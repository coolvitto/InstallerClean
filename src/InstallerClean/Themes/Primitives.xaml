<!--
    Primitive design atoms (colour only).

    Layering rule: Tokens.xaml maps semantic roles to primitives;
    component styles and window XAML consume the semantic roles, never
    a Primitive.* key directly. If a non-Tokens file references
    Primitive.*, that is a smell to fix.

    XAML resource type-matching: a property consuming
    {StaticResource X} requires X's runtime type to match the property's
    declared type exactly. The XAML resource lookup does not run any
    TypeConverter (ThicknessConverter etc), so a Double resource will
    not satisfy a Thickness setter. Numeric tokens with multiple
    consumer-property types therefore need parallel resources of each
    type (see BorderThickness.* / Border.* in Tokens.xaml). Inline
    attribute syntax does run TypeConverters, so BorderThickness="1"
    is fine; only StaticResource lookups have the strict-typing rule.

    Naming: <ramp>.<step>. Steps follow Tailwind's convention so that
    swapping a primitive for a different shade reads as a numeric move
    (Slate.700 darker than Slate.500). Alpha-blended variants use a
    trailing AlphaNN suffix indicating the intended opacity.
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Slate ramp. Surface, structure, text. -->
    <Color x:Key="Primitive.Slate.50">#f8fafc</Color>
    <Color x:Key="Primitive.Slate.300">#cbd5e1</Color>
    <Color x:Key="Primitive.Slate.400">#94a3b8</Color>
    <Color x:Key="Primitive.Slate.500">#8494a7</Color>
    <Color x:Key="Primitive.Slate.600">#475569</Color>
    <Color x:Key="Primitive.Slate.700">#334155</Color>
    <Color x:Key="Primitive.Slate.800">#1e293b</Color>
    <Color x:Key="Primitive.Slate.900">#0f172a</Color>
    <Color x:Key="Primitive.Slate.950">#020617</Color>

    <!-- Custom slate steps used for hover/pressed states on Primary
         buttons. Sit between Slate.700 and Slate.800; not on the
         Tailwind ramp. -->
    <Color x:Key="Primitive.Slate.700.Hover">#2b3749</Color>
    <Color x:Key="Primitive.Slate.700.Pressed">#232e3d</Color>

    <Color x:Key="Primitive.Slate.50.Alpha20">#33f8fafc</Color>
    <Color x:Key="Primitive.Slate.50.Alpha50">#80f8fafc</Color>
    <Color x:Key="Primitive.Slate.950.Alpha50">#80020617</Color>

    <!-- Indigo ramp. Accent, CTA, links. -->
    <Color x:Key="Primitive.Indigo.400">#818cf8</Color>
    <Color x:Key="Primitive.Indigo.400.Alpha66">#A8818cf8</Color>
    <Color x:Key="Primitive.Indigo.600">#4f46e5</Color>
    <Color x:Key="Primitive.Indigo.700">#443cc7</Color>
    <Color x:Key="Primitive.Indigo.800">#3b34af</Color>

    <!-- Violet. One step only — used for the selection accent. -->
    <Color x:Key="Primitive.Violet.700">#6d28d9</Color>

    <!-- Red ramp. Destructive actions and the close-window caption. -->
    <Color x:Key="Primitive.Red.500">#ef4444</Color>
    <Color x:Key="Primitive.Red.700.CaptionHover">#c0392b</Color>
    <Color x:Key="Primitive.Red.700.CaptionPressed">#a93226</Color>
    <Color x:Key="Primitive.Red.900">#991b1b</Color>
    <Color x:Key="Primitive.Red.950">#7f1d1d</Color>
    <Color x:Key="Primitive.Red.950.Pressed">#6b1a1a</Color>

    <!-- Status colours. -->
    <Color x:Key="Primitive.Amber.400">#fbbf24</Color>
    <Color x:Key="Primitive.Amber.500">#f59e0b</Color>
    <Color x:Key="Primitive.Green.400">#4ade80</Color>

</ResourceDictionary>
