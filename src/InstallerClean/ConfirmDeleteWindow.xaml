<Window x:Class="InstallerClean.ConfirmDeleteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:loc="clr-namespace:InstallerClean.Resources"
        Title="{loc:Translate Window.ConfirmDelete.Title}"
        AutomationProperties.HelpText="{loc:Translate Automation.ConfirmDelete}"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <WindowChrome.WindowChrome>
        <!-- CaptionHeight=0: this is a centred-on-owner modal with no
             title-bar buttons, so no drag region is needed and the
             Border below claims the full window. -->
        <WindowChrome CaptionHeight="0" GlassFrameThickness="0"
                      ResizeBorderThickness="0"/>
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource Surface.Card}" CornerRadius="{StaticResource Radius.Card}" Padding="{StaticResource Padding.ModalCard}"
            MaxWidth="400" MinWidth="320"
            BorderBrush="{StaticResource Action.Primary.Background}" BorderThickness="{StaticResource BorderThickness.Hairline}">
        <StackPanel>
            <!-- No warning icon: a delete to the Recycle Bin is the normal,
                 safe action InstallerClean exists for, not a hazard to flag.
                 Standalone wrapping TextBlock so a long heading grows the
                 SizeToContent card instead of clipping. -->
            <TextBlock x:Name="MessageText" Foreground="{StaticResource Text.Heading}" FontSize="{DynamicResource Type.Heading.Sm}"
                       TextWrapping="Wrap" Margin="{StaticResource GapBottom.Md}"/>

            <TextBlock
                       Text="{loc:Translate Confirm.DeleteToRecycleBin}"
                       Foreground="{StaticResource Text.Muted}" FontSize="{DynamicResource Type.Body}" TextWrapping="Wrap"
                       Margin="{StaticResource GapBottom.Lg}"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- Cancel is the default to stop a reflexive Enter from
                     deleting; affirmative click requires explicit pointer
                     or Tab+Space. -->
                <Button x:Name="CancelButton" Style="{StaticResource GhostPill}" Content="{loc:Translate Action.Cancel}"
                        Click="OnCancel" IsCancel="True" IsDefault="True"
                        Margin="{StaticResource GapRight.Sm}"/>
                <Button x:Name="DeleteButton" Style="{StaticResource DangerPill}"
                        Content="{loc:Translate Action.Delete}" Click="OnDelete"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
